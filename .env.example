# Copy to .env and fill in. All optional — app runs without them.

# Adzuna (optional, more job sources) — free at https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=gb

# Email notifications (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL=

# Security
SECRET_KEY=change-me-to-a-random-string
