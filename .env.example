# Copy to .env and fill in. All optional — app runs without them.

# Adzuna (optional, more job sources) — free at https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=gb

# Email notifications (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL=

# Security
SECRET_KEY=change-me-to-a-random-string

# ── JobHunter (this app) ───────────────────────────────────────────────
# Discovery source: seed (demo) | hackernews (live public) | upwork (stub)
JOB_SOURCE=seed

# Email-apply (SMTP). Leave blank to run in dry-run (composes email, sends nothing).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
# Where applications are sent. Leave blank -> dry-run (nothing transmitted).
APPLY_TO=
